<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <ImageView
            android:id="@+id/record_alarm_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_alarm"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="17dp"
            android:layout_marginRight="17dp"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/record_plus_cl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="parent"
            android:background="@drawable/record_plus_layout"
            android:layout_marginLeft="16dp"
            app:layout_constraintTop_toBottomOf="@+id/record_alarm_iv"
            android:layout_marginTop="26dp"
            >

            <TextView
                android:id="@+id/record_plus_tv"
                android:text="+"
                android:textColor="@color/white"
                android:paddingVertical="4dp"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                android:paddingHorizontal="20dp"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/record_main_cl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="parent"
            android:background="@drawable/record_box_line"
            app:layout_constraintTop_toBottomOf="@+id/record_plus_cl"
            android:layout_marginTop="15dp"
            android:layout_marginHorizontal="8dp"
            >

            <ImageView
                android:id="@+id/record_main_iv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/record_main_image"
                android:paddingVertical="30dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginLeft="20dp"
                />

            <TextView
                android:id="@+id/record_main_tv"
                android:text="@string/record_main_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintLeft_toRightOf="@id/record_main_iv"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/Pome.SemiBold.16"
                android:textColor="@color/grey_9"
                android:layout_marginTop="40dp"
                android:layout_marginLeft="20dp"
                />

            <TextView
                android:id="@+id/record_main_tv2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/main"
                android:text="@string/record_main_text2"
                app:layout_constraintTop_toBottomOf="@id/record_main_tv"
                app:layout_constraintLeft_toRightOf="@id/record_main_iv"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="10dp"/>

            <ImageView
                android:id="@+id/record_arrow"
                android:src="@drawable/ic_arrow_right_24"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="@id/record_main_tv2"
                app:layout_constraintBottom_toBottomOf="@id/record_main_tv2"
                app:layout_constraintLeft_toRightOf="@id/record_main_tv2"/>



        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageView
            android:id="@+id/record_ic_write_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_fab_writing"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginBottom="-25dp"/>

        <TextView
            android:id="@+id/record_week_tv"
            android:text="@string/record_week_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Pome.SemiBold.16"
            android:textColor="@color/grey_9"
            app:layout_constraintTop_toBottomOf="@id/record_main_cl"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="20dp"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/record_main_cl2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/record_main2_layout"
            app:layout_constraintTop_toBottomOf="@id/record_week_tv"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            >

            <ImageView
                android:id="@+id/record_ic_love_iv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_main_love"
                android:paddingVertical="15dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                android:layout_marginLeft="12dp"
                />

            <TextView
                android:id="@+id/record_main_tv3"
                android:text="@string/record_week_text2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="@+id/record_main_cl2"
                app:layout_constraintLeft_toRightOf="@id/record_ic_love_iv"
                style="@style/Pome.SemiBold.16"
                android:textColor="@color/grey_9"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="14dp"
                />

            <TextView
                android:id="@+id/record_main_tv4"
                android:text="@string/record_week_text3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/record_main_tv3"
                app:layout_constraintLeft_toRightOf="@id/record_ic_love_iv"
                style="@style/Pome.SemiBold.16"
                android:textColor="@color/grey_6"
                android:layout_marginLeft="10dp"
                />

            <ImageView
                android:id="@+id/record_arrow_week"
                android:src="@drawable/ic_arrow_right_24"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="@id/record_main_tv3"
                app:layout_constraintBottom_toBottomOf="@id/record_main_tv3"
                app:layout_constraintRight_toRightOf="parent"
                android:layout_marginRight="14dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/record_noting_cl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/record_main_cl2"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            >

            <ImageView
                android:id="@+id/ic_noting_iv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_noting"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                />

            <TextView
                android:id="@+id/ic_noting_tv"
                android:text="@string/record_noting_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/grey_5"
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ic_noting_iv"/>



        </androidx.constraintlayout.widget.ConstraintLayout>






    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>